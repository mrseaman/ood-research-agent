# Research Agent - Environment Configuration
# Copy this file to .env.local and fill in your values.

# ============================================
# Branding (optional, customize for your org)
# ============================================
# RA_APP_NAME=Research Agent
# RA_APP_NAME_ZH=
# RA_APP_FULL_NAME=Research Agent
# RA_APP_ORG=Your Organization Name

# ============================================
# LLM Models (at least one model required)
# ============================================
# List model IDs (comma-separated)
RA_MODELS=default

# Per-model settings: RA_MODEL_{ID}_NAME, _ENDPOINT, _TOKEN, _MODEL
# ID is uppercased; hyphens and dots become underscores
RA_MODEL_DEFAULT_NAME=Default
RA_MODEL_DEFAULT_ENDPOINT=http://localhost:8080/v1/chat/completions
RA_MODEL_DEFAULT_TOKEN=
RA_MODEL_DEFAULT_MODEL=default

# Example: multiple models
# RA_MODELS=deepseek
# RA_MODEL_DEEPSEEK_NAME=DeepSeek
# RA_MODEL_DEEPSEEK_ENDPOINT=https://api.deepseek.com/chat/completions
# RA_MODEL_DEEPSEEK_TOKEN=sk-...
# RA_MODEL_DEEPSEEK_MODEL=deepseek-chat

# ============================================
# Web Search (optional)
# ============================================
# Backend: "searxng" (default, self-hosted), "tavily", "serper", "bing"
# RA_SEARCH_ENGINE=searxng
# RA_SEARCH_ENDPOINT=http://localhost:8888
# RA_SEARCH_API_KEY=

# ============================================
# General Settings
# ============================================
RA_MAX_TOOL_ITERATIONS=10
RA_MAX_FILE_SIZE=102400
RA_ALLOWED_PATHS=/home,/scratch,/work
RA_SCHEDULER=slurm

# Set to 0 if your LLM endpoint uses a self-signed certificate
# NODE_TLS_REJECT_UNAUTHORIZED=0
